{
  "name": "founder-content-api",
  "private": true,
  "version": "0.1.0",
  "description": "Express API for FounderContent AI",
  "main": "server.ts",
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "pg": "^8.13.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/applyMigrations.ts",
    "db:migrate:status": "tsx scripts/applyMigrations.ts --status",
    "db:bootstrap-ledger": "tsx scripts/applyMigrations.ts --bootstrap-ledger",
    "stripe:bootstrap-catalog": "tsx scripts/bootstrapStripeCatalog.ts",
    "stripe:bootstrap-email": "tsx scripts/bootstrapStripeCatalog.ts --scope=email",
    "smoke:scheduler": "tsx scripts/schedulerSmoke.ts",
    "worker": "tsx src/workers/appWorker.ts",
    "worker:scheduled-posts": "tsx src/workers/scheduledPostWorker.ts",
    "worker:email-campaigns": "tsx src/workers/emailCampaignWorker.ts",
    "worker:email-deliverability": "tsx src/workers/emailDeliverabilityWorker.ts",
    "worker:growth-automation": "tsx src/workers/growthAutomationWorker.ts",
    "export:workspace-blogs": "tsx scripts/exportWorkspaceBlogs.ts",
    "export:workspace-blogs:all": "tsx scripts/exportWorkspaceBlogs.ts --all",
    "worker:blog-exports": "tsx src/workers/workspaceBlogExportWorker.ts",
    "worker:blog-exports:once": "BLOG_EXPORT_WORKER_RUN_ONCE=true tsx src/workers/workspaceBlogExportWorker.ts",
    "publish:workspace-blog": "tsx scripts/publishWorkspaceBlogToWebsite.ts",
    "publish:sudo-programmer-blog": "tsx scripts/publishWorkspaceBlogToWebsite.ts --workspace=sudo-programmer",
    "publish:sudo-programmer-blog:build": "tsx scripts/publishWorkspaceBlogToWebsite.ts --workspace=sudo-programmer --build"
  }
}
