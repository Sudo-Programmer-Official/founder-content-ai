{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "./server.ts",
    "./src/**/*.ts",
    "../../packages/shared-types/**/*.ts",
    "../../packages/content-engine/**/*.ts",
    "../../packages/prompts/**/*.ts"
  ]
}
