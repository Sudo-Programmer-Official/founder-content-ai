# Environment files and secrets
.env
.env.*
!.env.example
!.env.*.example

# App-level env files
apps/*/.env
apps/*/.env.*
!apps/*/.env.example
!apps/*/.env.*.example

# Dependencies
node_modules/

# Build output
dist/
build/
.cache/
coverage/

# Local transpilation artifacts next to source files
apps/founder-content-ai/*.js
apps/founder-content-ai/access/*.js
apps/founder-content-ai/auth/*.js
apps/founder-content-ai/components/**/*.js
apps/founder-content-ai/composables/*.js
apps/founder-content-ai/pages/*.js
apps/founder-content-ai/preferences/*.js
apps/founder-content-ai/services/*.js
apps/founder-content-ai/utils/*.js
packages/shared-types/*.js
packages/shared-types/src/*.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor files
.DS_Store
.idea/
.vscode/
